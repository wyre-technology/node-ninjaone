{
  "name": "@wyre-technology/node-ninjaone",
  "version": "1.1.3",
  "type": "module",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "description": "Comprehensive, fully-typed Node.js/TypeScript library for the NinjaOne/NinjaRMM API",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ninjaone",
    "ninjarmm",
    "rmm",
    "msp",
    "api",
    "typescript",
    "remote-monitoring",
    "endpoint-management"
  ],
  "author": "Wyre Technology",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wyre-technology/node-ninjaone.git"
  },
  "bugs": {
    "url": "https://github.com/wyre-technology/node-ninjaone/issues"
  },
  "homepage": "https://github.com/wyre-technology/node-ninjaone#readme",
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@types/node": "^26.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9.39.4",
    "globals": "^17.6.0",
    "msw": "^2.1.0",
    "semantic-release": "^25.0.5",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^3.2.6"
  }
}
